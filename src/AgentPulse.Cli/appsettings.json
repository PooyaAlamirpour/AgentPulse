{
  "AgentPulse": {
    "Cli": {
      "ApplicationName": "agentpulse"
    },
    "SessionRun": {
      "LeaseDuration": "00:05:00"
    },
    "Streaming": {
      "FlushInterval": "00:00:00.5000000",
      "FlushCharacterThreshold": 256,
      "LeaseRenewInterval": "00:01:00",
      "CleanupTimeout": "00:00:05"
    },
    "Model": {
      "BaseUrl": "https://api.openai.com/v1",
      "ChatCompletionsPath": "chat/completions",
      "Model": "gpt-4.1-mini",
      "AuthenticationMode": "Bearer",
      "ApiKeyHeaderName": "api-key",
      "ApiKeyEnvironmentVariable": "OPENAI_API_KEY",
      "MaxCompletionTokens": 4096,
      "ThinkingMode": "disabled",
      "IncludeThinkingConfiguration": false,
      "FirstByteTimeout": "00:00:30",
      "StreamIdleTimeout": "00:01:00",
      "ErrorBodyReadTimeout": "00:00:10"
    },
    "Tools": {
      "MaxToolIterations": 8,
      "MaxOutputCharacters": 30000,
      "MaxGlobResults": 200,
      "MaxGrepResults": 100,
      "MaxReadLines": 500,
      "MaxReadableFileBytes": 5242880,
      "MaxGrepFileBytes": 2097152,
      "ToolTimeout": "00:00:30",
      "Mutation": {
        "MaxFileBytes": 5242880,
        "MaxPatchBytes": 1048576,
        "MaxDiffPreviewCharacters": 12000,
        "DiffContextLines": 3,
        "ProtectedPatterns": [
          ".git",
          ".git/**",
          "**/bin",
          "**/bin/**",
          "**/obj",
          "**/obj/**",
          ".vs",
          ".vs/**",
          "**/TestResults",
          "**/TestResults/**",
          "**/artifacts",
          "**/artifacts/**"
        ]
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft": "None",
      "Microsoft.Hosting.Lifetime": "Warning"
    }
  }
}
